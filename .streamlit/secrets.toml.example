# Copy to .streamlit/secrets.toml (local) or paste into the Streamlit Cloud
# "Secrets" box (app settings). Every value is optional: with none set, the app
# runs on SQLite + an in-process store. Set these to attach a real, persistent
# cloud database so data survives restarts and redeploys.

# Ledger: a hosted Postgres. Neon or Supabase (both free, both include pgvector).
# Use the POOLED connection string (Neon "-pooler" host) for efficiency.
# DATABASE_URL = "postgresql://USER:PASSWORD@HOST-pooler.REGION.neon.tech/DB?sslmode=require"

# Hot store: a hosted Redis. Upstash (free, serverless).
# REDIS_URL = "rediss://default:PASSWORD@HOST.upstash.io:6379"

# Optional: real Claude grounding for the agent (otherwise a deterministic stub).
# ANTHROPIC_API_KEY = "sk-ant-..."
