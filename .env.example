# Copy to .env. Every value is optional: the demo runs fully offline with defaults.
# No secrets belong in code — they are read from the environment only.

# Layer 1 — system of record. If unset, a local SQLite file is used.
# PROD: swap for Snowflake / Databricks connection string.
# DATABASE_URL=postgresql://bfsi:bfsi@localhost:5432/bfsi

# Layer 1/2 — online hot-path store. If unset, an in-process dict store is used.
# PROD: swap for ElastiCache (Redis) / DynamoDB.
# REDIS_URL=redis://localhost:6379/0

# Layer 3 — grounded LLM. If unset, a deterministic offline stub answers with citations.
# PROD: swap for Bedrock / a hosted Claude endpoint.
# ANTHROPIC_API_KEY=
# LLM_MODEL=claude-sonnet-5

# Demo knobs
SEED_PARTIES=10000
LATENCY_SLO_MS=98
